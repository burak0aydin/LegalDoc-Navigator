# Local LLM (LM Studio OpenAI-compatible server)
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_MODEL=gemma-3-4b-it
LMSTUDIO_TIMEOUT_SEC=600

# Local Embedding Model (HuggingFace)
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
HF_EMBEDDING_BATCH_SIZE=32

# Vector database configuration
VECTOR_DB_PROVIDER=chromadb
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=legal_documents
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Application configuration
APP_ENV=development
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
APP_NAME=LegalDoc Navigator API
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173,http://localhost:4174,http://127.0.0.1:4174,http://localhost:3000,http://127.0.0.1:3000

# Document Processing
UPLOAD_DIR=./data/uploads
PDF_CHUNK_SIZE=2000
PDF_CHUNK_OVERLAP=500
PDF_MAX_FILE_SIZE_MB=40
